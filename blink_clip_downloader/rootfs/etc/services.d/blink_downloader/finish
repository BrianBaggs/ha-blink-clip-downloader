#!/usr/bin/with-contenv bashio
# ==============================================================================
# Called by S6 when the service exits.
# Non-zero exit (except 256 = intentional stop) halts the add-on container.
# ==============================================================================

declare APP_EXIT_CODE=${1}

if [[ "${APP_EXIT_CODE}" -ne 0 ]] && [[ "${APP_EXIT_CODE}" -ne 256 ]]; then
    bashio::log.warning "Blink Clip Downloader exited with code ${APP_EXIT_CODE}"
    echo "${APP_EXIT_CODE}" > /run/s6-linux-init-container-results/exitcode
    exec /run/s6/basedir/bin/halt
fi

bashio::log.info "Blink Clip Downloader stopped cleanly"
